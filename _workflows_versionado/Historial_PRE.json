  {
   "id": "n10",
   "name": "Flatten files",
   "type": "n8n-nodes-base.code",
   "typeVersion": 2,
   "position": [
    2080,
    400
   ],
   "parameters": {
    "language": "javaScript",
    "jsCode": "\nconst items = $input.all();\nconst planItems = $('Build copy plan').all();\nconst out = [];\nfor (let i = 0; i < items.length; i++) {\n  const plan = planItems[i].json;\n  const files = items[i].json.files || [];\n  for (const f of files) {\n    if (f.mimeType === 'application/vnd.google-apps.folder') continue;\n    out.push({ json: { fileId: f.id, fileName: f.name, srcId: plan.srcId, srcKey: plan.srcKey, targetId: plan.targetId } });\n  }\n}\nif (out.length === 0) return [{ json: { _empty: true, fileId:'NOOP', srcId:'NOOP', targetId:'NOOP' } }];\nreturn out;\n"
   }
  },
