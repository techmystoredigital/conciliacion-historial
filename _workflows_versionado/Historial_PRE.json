   "typeVersion": 2,
   "position": [
    760,
    400
   ],
   "parameters": {
    "language": "javaScript",
    "jsCode": "\nconst ts_id = $json.id;\nreturn [\n  { json: { name: '1_VIRTUALSOFT_Cajas',     parents: [ts_id], _key: 'CAJAS' } },\n  { json: { name: '2_BANCOS_COOP',           parents: [ts_id], _key: 'BANCOS_PADRE' } },\n  { json: { name: '3_RESUMEN_MOVIMIENTOS',   parents: [ts_id], _key: 'RESUM_PADRE' } },\n  { json: { name: '4_RECARGAS_YOPAGO',       parents: [ts_id], _key: 'YOPAGO' } },\n];\n"
   }
  },
  {
