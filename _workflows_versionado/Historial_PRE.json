  {
   "id": "n8",
   "name": "Build copy plan",
   "type": "n8n-nodes-base.code",
   "typeVersion": 2,
   "position": [
    1640,
    400
   ],
   "parameters": {
    "language": "javaScript",
    "jsCode": "\nconst setup = $('Setup PRE').first().json;\nconst topItems = $('Create top folders').all();\nconst topPlan = $('Plan top folders').all();\nconst subItems = $('Create sub folders').all();\nconst subPlan = $('Plan sub folders').all();\nconst m = {};\nfor (let i = 0; i < topItems.length; i++) m[topPlan[i].json._key] = topItems[i].json.id;\nfor (let i = 0; i < subItems.length; i++) m[subPlan[i].json._key] = subItems[i].json.id;\nreturn [\n  { json: { srcKey: '1_VIRTUALSOFT', srcId: setup.source_1_virtualsoft, targetId: m.CAJAS  } },\n  { json: { srcKey: '2a_VALLES',     srcId: setup.source_2a_valles,     targetId: m.B2A    } },\n  { json: { srcKey: '2b_CREDIL',     srcId: setup.source_2b_credil,     targetId: m.B2B    } },\n  { json: { srcKey: '3a_VALLES',     srcId: setup.source_3a_valles,     targetId: m.R3A    } },\n  { json: { srcKey: '3b_CREDIL',     srcId: setup.source_3b_credil,     targetId: m.R3B    } },\n  { json: { srcKey: 'YOPAGO',        srcId: setup.source_yopago,        targetId: m.YOPAGO } },\n];\n"
   }
  },
  {
   "id": "n9",
   "name": "List source",
   "type": "n8n-nodes-base.httpRequest",
   "typeVersion": 4.2,
