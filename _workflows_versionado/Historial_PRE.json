   ],
   "parameters": {
    "language": "javaScript",
    "jsCode": "\nconst topItems = $('Create top folders').all();\nconst topPlan = $('Plan top folders').all();\nconst map = {};\nfor (let i = 0; i < topItems.length; i++) map[topPlan[i].json._key] = topItems[i].json.id;\nconst banc = map.BANCOS_PADRE, resum = map.RESUM_PADRE;\nreturn [\n  { json: { name: '2a_Banco_Valles_del_Lirio',   parents: [banc], _key: 'B2A' } },\n  { json: { name: '2b_Banco_Credil',             parents: [banc], _key: 'B2B' } },\n  { json: { name: '3a_Resumen_Valles_del_Lirio', parents: [resum], _key: 'R3A' } },\n  { json: { name: '3b_Resumen_Credil',           parents: [resum], _key: 'R3B' } },\n];\n"
   }
  },
