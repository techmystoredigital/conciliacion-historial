    "jsCode": "\nconst tsCreate = $('Create timestamp folder').first().json;\nconst copied = $('Copy to historial').all().map(i => i.json).filter(j => !j._empty);\nreturn [{ json: { ts_id: tsCreate.id, ts_name: tsCreate.name, copiedCount: copied.length } }];\n"
   }
