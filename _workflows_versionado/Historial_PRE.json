   "id": "n2",
   "name": "Setup PRE",
   "type": "n8n-nodes-base.code",
   "typeVersion": 2,
   "position": [
    320,
    400
   ],
   "parameters": {
    "language": "javaScript",
    "jsCode": "\nconst tz = 'America/Bogota';\nconst now = new Date();\nconst fmt = new Intl.DateTimeFormat('en-CA', {\n  timeZone: tz, year:'numeric', month:'2-digit', day:'2-digit',\n  hour:'2-digit', minute:'2-digit', second:'2-digit', hour12:false\n}).formatToParts(now);\nconst g = (t) => fmt.find(p => p.type === t).value;\nconst yyyy = g('year'), mm = g('month'), dd = g('day');\nconst tstamp = `${yyyy}-${mm}-${dd}_${g('hour')}-${g('minute')}-${g('second')}`;\nreturn [{ json: {\n  tstamp, yyyy, mm, dd,\n  historial_root: '11G2g89t9dyLWt0kFF4X7GUNx4SqrE8OL',\n  source_1_virtualsoft: '12zjruSVCy7ZSP6XrcToed2N0NKfx6L6c',\n  source_2a_valles:     '17Ut-5dL7ci9RZZhX72iD8qejZZdKnNkh',\n  source_2b_credil:     '177YEDw4l3-RD7Vg7rG9-ApGyey7Kh3tn',\n  source_3a_valles:     '1KZt98PYd9V6w_zfSpl-fOl6F1v56Vb4t',\n  source_3b_credil:     '12jatMOkDTNHzIwwPZOlHnWc33uoqcxwM',\n  source_yopago:        '1nd2P5MG-eTDPHpeTzWIqlJpzo6k8rap6',\n} }];\n"
   }
  },
  {
   "id": "n3",
   "name": "Create timestamp folder",
   "type": "n8n-nodes-base.httpRequest",
   "typeVersion": 4.2,
