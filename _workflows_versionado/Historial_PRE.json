      {
       "name": "supportsAllDrives",
       "value": "true"
      },
      {
       "name": "fields",
       "value": "id,name,parents"
      }
     ]
    },
    "sendBody": true,
    "contentType": "json",
    "specifyBody": "json",
    "jsonBody": "={{ JSON.stringify({ name: $json.tstamp, mimeType: \"application/vnd.google-apps.folder\", parents: [$json.historial_root] }) }}"
